# Copy this file to `android/keystore.properties` and fill in real values.
# DO NOT commit the real keystore.properties — it is gitignored.
#
# Generate a release keystore (one-time):
#   keytool -genkey -v -keystore auropay-release.keystore \
#     -alias auropay -keyalg RSA -keysize 2048 -validity 10000
#
# Then move auropay-release.keystore into android/app/ (also gitignored).

storeFile=auropay-release.keystore
storePassword=CHANGE_ME
keyAlias=auropay
keyPassword=CHANGE_ME
